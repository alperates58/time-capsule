# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER="timecapsule_user"
POSTGRES_PASSWORD="timecapsule_secure_password"
POSTGRES_DB="timecapsule"

# PostgreSQL connection string
# Local standalone DB example: postgresql://postgres:postgres@localhost:5432/timecapsule?schema=public
# Docker Compose environment format (maps to the variables above)
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public"

# The base URL of the site, used for absolute URLs in metadata and sitemaps.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Set to "production" in production environments
NODE_ENV="development"
