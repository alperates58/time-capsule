# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# PostgreSQL connection string
# Local example: postgresql://postgres:postgres@localhost:5432/timecapsule?schema=public
# Docker example: postgresql://postgres:postgres@db:5432/timecapsule?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/timecapsule?schema=public"

# The base URL of the site, used for absolute URLs in metadata and sitemaps.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Set to "production" in production environments
NODE_ENV="development"
